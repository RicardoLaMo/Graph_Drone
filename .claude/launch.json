{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "JupyterLab (default 8888)",
      "runtimeExecutable": "jupyter",
      "runtimeArgs": ["lab", "--ip=127.0.0.1", "--no-browser"],
      "port": 8888
    },
    {
      "name": "JupyterLab (alternate 8889)",
      "runtimeExecutable": "jupyter",
      "runtimeArgs": ["lab", "--ip=127.0.0.1", "--no-browser", "--port=8889"],
      "port": 8889
    }
  ]
}
